# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Only needed for server-side admin operations (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Gmail SMTP (email delivery — free, no domain needed)
# Create an App Password at https://myaccount.google.com/apppasswords
GMAIL_USER=liagiorgi.one@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password-here

# Lia's email for booking notifications
LIA_EMAIL=liagiorgi.one@gmail.com

# Site URL (used in email links)
NEXT_PUBLIC_SITE_URL=https://lia-tattoo.vercel.app

# Google Calendar — booking slot management
# Service account JSON key, base64-encoded: cat key.json | base64 | tr -d '\n'
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com
GOOGLE_SERVICE_ACCOUNT_KEY=base64-encoded-service-account-json-key
